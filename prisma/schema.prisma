// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "./fresh-client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Models

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String   // In a real app, hashed. For MVP, simple text or hashed if we add auth lib
  name      String?
  role      String     @default("CLIENT") // ADMIN, EMPLOYEE, CLIENT
  phone     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Role specific relations
  clientProfile ClientProfile?
  employeeProfile EmployeeProfile?
}

model ClientProfile {
  id     String @id @default(uuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id])
  
  address      String?
  latitude     Float?
  longitude    Float?
  
  loyaltyPoints Int @default(0)
  
  // B2B Relation
  warranties      Warranty[]
  waitlistEntries WaitlistEntry[]
  businessId   String?
  business     BusinessProfile? @relation(fields: [businessId], references: [id])

  // Referral System
  referralCode  String @unique @default(uuid())
  referredById  String?
  referredBy    ClientProfile? @relation("Referrals", fields: [referredById], references: [id])
  referrals     ClientProfile[] @relation("Referrals")
  accessKey     String? @unique @default(uuid()) // "Magic Link" token for Live Status view

  npsScore           Int?
  lastMarketingSent  DateTime?
  lastBookingDate    DateTime?

  vehicles     Vehicle[]
  jobs         Job[]
}

model EmployeeProfile {
  id     String @id @default(uuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id])

  hourlyRate    Float?
  availabilities Availability[]
  assignedJobs  Job[]
  
  // Gamification
  experience    Int @default(0)
  level         Int @default(1)
  badges        EmployeeBadge[]

  // New Many-to-Many relation
  teamJobs      Job[] @relation("JobTeam")
}

model Badge {
  id          String   @id @default(uuid())
  name        String
  description String?
  icon        String   // Lucide icon name or emoji
  criteria    String?  // Description of how to earn it
  
  employees   EmployeeBadge[]
}

model EmployeeBadge {
  employeeId String
  employee   EmployeeProfile @relation(fields: [employeeId], references: [id])
  badgeId    String
  badge      Badge @relation(fields: [badgeId], references: [id])
  earnedAt   DateTime @default(now())

  @@id([employeeId, badgeId])
}

model Availability {
  id String @id @default(uuid())
  employeeId String
  employee   EmployeeProfile @relation(fields: [employeeId], references: [id])
  
  dayOfWeek Int // 0=Sunday, 1=Monday...
  date      DateTime? // Specific date for non-recurring
  isLocked  Boolean @default(false)
  startTime String // "09:00"
  endTime   String // "17:00"
}

model Vehicle {
  id        String      @id @default(uuid())
  clientId  String
  client    ClientProfile @relation(fields: [clientId], references: [id])
  
  type      String // SEDAN, SUV, PICKUP, TRUCK, OTHER
  make      String
  model     String
  year      Int?
  color     String?
  licensePlate String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  businessId String?
  business   BusinessProfile? @relation(fields: [businessId], references: [id])

  jobs      Job[]
  warranties Warranty[]
}

model Service {
  id          String @id @default(uuid())
  name        String
  description String?
  basePrice   Float
  durationMin Int    @default(60)

  extras ServiceExtra[]
  jobs   JobService[]
  warranties Warranty[]
}

/// Options par service (VUS, pickup, dégâts majeurs, etc.) — supplément prix / durée
model ServiceExtra {
  id               String  @id @default(uuid())
  serviceId        String
  service          Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  label            String
  priceExtra       Float   @default(0)
  durationExtraMin Int     @default(0)
  sortOrder        Int     @default(0)

  @@index([serviceId])
}


model Job {
  id        String    @id @default(uuid())
  clientId  String
  client    ClientProfile @relation(fields: [clientId], references: [id])
  
  vehicleId String?
  vehicle   Vehicle? @relation(fields: [vehicleId], references: [id])

  employeeId String?
  employee   EmployeeProfile? @relation(fields: [employeeId], references: [id])

  // New Many-to-Many relation for multi-assignment
  employees EmployeeProfile[] @relation("JobTeam")

  status    String @default("PENDING") // PENDING, CONFIRMED, IN_PROGRESS, COMPLETED, CANCELLED
  color     String? // Hex code for calendar
  scheduledDate DateTime
  
  services  JobService[]
  
  totalPrice Float?
  notes      String?

  productUsages ProductUsage[]
  inspections   Inspection[]
  timeLogs      TimeLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model JobService {
  jobId     String
  job       Job     @relation(fields: [jobId], references: [id], onDelete: Cascade)
  serviceId String
  service   Service @relation(fields: [serviceId], references: [id])

  /// IDs des ServiceExtra choisis pour cette ligne (JSON array de strings)
  selectedExtraIds Json?
  isDone           Boolean @default(false)

  @@id([jobId, serviceId])
}

model InventoryItem {
  id        String   @id @default(uuid())
  name      String
  quantity  Float
  unit      String   // "Liters", "Bottles"
  minThreshold Float @default(10)
  type      String   // "PRODUCT", "EQUIPMENT"
  sdsUrl    String?  // Link to Safety Data Sheet (PDF)
  
  updatedAt DateTime @updatedAt
  usages    ProductUsage[]
}

model ProductUsage {
  id        String   @id @default(uuid())
  jobId     String
  job       Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  
  itemId    String
  item      InventoryItem @relation(fields: [itemId], references: [id])
  
  quantityUsed Float
  unit         String
  createdAt    DateTime @default(now())
}

model Expense {
  id          String   @id @default(uuid())
  date        DateTime @default(now())
  category    String
  amount      Float
  description String?
}

// === NEW MODELS FOR V45 ===

model Inspection {
  id        String   @id @default(uuid())
  jobId     String
  job       Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  
  type      String   @default("CHECK_IN") // CHECK_IN, CHECK_OUT
  notes     String?
  points    InspectionPoint[]
  photos    String? // JSON array of global photo URLs

  createdAt DateTime @default(now())
  createdBy String?  // Employee ID usually
}

model InspectionPoint {
  id           String     @id @default(uuid())
  inspectionId String
  inspection   Inspection @relation(fields: [inspectionId], references: [id], onDelete: Cascade)
  
  x            Float      // % from left
  y            Float      // % from top
  type         String     // "SCRATCH", "DENT", "CHIP", "OTHER"
  severity     String?    // "LOW", "MEDIUM", "HIGH"
  photoUrl     String?
  notes        String?
}

model TimeLog {
  id         String   @id @default(uuid())
  jobId      String
  job        Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  
  employeeId String
  
  startTime  DateTime @default(now())
  endTime    DateTime? 
  
  durationMin Int?    // Calculated on completion
}

model BusinessProfile {
  id          String   @id @default(uuid())
  name        String
  contactName String?
  email       String?
  phone       String?
  address     String?
  
  clients     ClientProfile[]
  vehicles    Vehicle[]
  warranties  Warranty[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model GiftCard {
  id            String   @id @default(uuid())
  code          String   @unique
  initialAmount Float
  currentAmount Float
  expiryDate    DateTime?
  
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model WaitlistEntry {
  id            String   @id @default(uuid())
  clientId      String
  client        ClientProfile @relation(fields: [clientId], references: [id])
  
  preferredDate DateTime?
  status        String   @default("WAITING") // WAITING, NOTIFIED, BOOKED, EXPIRED
  
  createdAt     DateTime @default(now())
}

model Warranty {
  id            String   @id @default(uuid())
  clientId      String
  client        ClientProfile @relation(fields: [clientId], references: [id])
  
  vehicleId     String
  vehicle       Vehicle       @relation(fields: [vehicleId], references: [id])
  
  serviceId     String
  service       Service       @relation(fields: [serviceId], references: [id])

  businessId    String?
  business      BusinessProfile? @relation(fields: [businessId], references: [id])

  certNumber    String   @unique
  issueDate     DateTime @default(now())
  expiryDate    DateTime
  
  status        String   @default("ACTIVE") // ACTIVE, EXPIRED, VOID
  
  createdAt     DateTime @default(now())
}
