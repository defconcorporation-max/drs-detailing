# Base de données (obligatoire) — PostgreSQL
# Supabase : Project Settings → Database → Connection string (URI). Pour Vercel, préférez Session mode (port 6543).
# Sinon : Neon https://neon.tech ou Postgres local.
# Sur Vercel : définissez cette variable dans Project Settings → Environment Variables
# Si le mot de passe contient des caractères spéciaux (? # @ etc.), encodez-les :
# ? → %3F   # → %23   @ → %40   [ → %5B   ] → %5D
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require"

# URL publique de l'app (pour les liens du portail client)
# Sur Vercel : remplacez par votre URL type https://votre-app.vercel.app
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Secret pour l'endpoint cron des rappels (POST /api/reminders/run)
# Exemple: openssl rand -hex 32
CRON_SECRET="change-me-long-random-secret"

# Emails de rappel (Resend) — https://resend.com
# Clé API + expéditeur vérifié (domaine ou onboarding@resend.dev en test, limité)
RESEND_API_KEY=""
# Exemple prod : "DRS Detailing <noreply@votredomaine.com>"
RESEND_FROM_EMAIL="onboarding@resend.dev"

# Routes /api/dev/* (db-push, sync) — désactivées en production sauf si mis à "true" (NE PAS activer sans contrôle d’accès)
ALLOW_DEV_API=""
